{
  // config loader accepts // comments, including inline end-of-line comments.
  "KNEXFILE_PG": {
    "client": "pg",
    "connection": ""
  },
  "KNEXFILE_MYSQL": {
    "client": "mysql",
    "connection": ""
  },
  "KEYV_CACHE": {

  },
  // SERVICES_CONFIG='[]'
  // types: redis=REDIS_CONFIG
  "SERVICES_TYPES_AVAILABLE": "auth,knex,keyv,ws", // NO LONGER NEEDED, use SERVICES_CONFIG
  "SERVICES_CONFIG": [
    {
      "name": "knex0",
      "type": "knex",
      "options": "KNEXFILE_MYSQL"
    },
    {
      "name": "knex1",
      "type": "knex",
      "options": "KNEXFILE_PG"
    },
    {
      "name": "keyv",
      "type": "keyv",
      "options": "KEYV_CACHE"
    },
    {
      "name": "ws",
      "type": "ws",
      "options": "WS_OPTIONS"
    }
  ],
  "CORS_OPTIONS": {
    "methods": "GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS",
    "preflightContinue": false,
    "optionsSuccessStatus": 204,
    "credentials": true,
    "origin": [
      "http://127.0.0.1:8080",
      "https://127.0.0.1:8080"
    ]
  },
  "HELMET_OPTIONS": null,
  "HELMET_OPTIONS-NA": {
    "hideServer": true,
    "csp": null,
    "nosniff": true,
    "xssfilter": true,
    "csp": {
      "directives": {
        "defaultSrc": ["self"],
        "scriptSrc": ["self","code.jquery.com","maxcdn.bootstrapcdn.com"],
        "styleSrc": ["self","maxcdn.bootstrapcdn.com"],
        "fontSrc": ["self","maxcdn.bootstrapcdn.com"]
      }
    }
  },
  "RES_HEADERS_ADD": {
    "Access-Control-Allow-Origin": "*"
  },
  "WEB_STATIC": [
    {
      "folder": "../../node_modules/@common/web",
      "url": "/esm"
    },
    {
      "folder": "public/openapi",
      "url": "/openapi",
      "options": {
        "icons": true,
        "list": true
      }
    },
    {
      "folder": "public/vue-nobundler",
      "url": "/native",
      "options": {
        "extensions": [
          "html"
        ],
        "index": false
      }
    },
    {
      "folder": "public/demo-express",
      "url": "/"
    }
  ],
  "UPLOAD_STATIC": [
    {
      "url": "/uploads",
      "options": {
        "limits": {
          "files": 2,
          "fileSize": 10000000
        }
      },
      "list": true,
      "listOptions": {
        "icons": true
      }
    }
  ],
  "SAML_OPTIONS": {
    "idpCert": "<Get From http://127.0.0.1:8081/realms/dev/protocol/saml/descriptor>",
    "cert": "<Get From http://127.0.0.1:8081/realms/dev/protocol/saml/descriptor>",
    "callbackUrl": "http://127.0.0.1:3000/api/saml/callback",
    "entryPoint": "http://127.0.0.1:8081/realms/dev/protocol/saml",
    "identifierFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:unspecified",
    "issuer": "dev-client-saml",
    "wantAuthnResponseSigned": true,
    "wantAssertionsSigned": false,
    "signatureAlgorithm": "sha256"
  },
  "SAML_JWT_MAP": {
    "id": "nameID",
    "groups": "Role"
  },
  "OIDC_OPTIONS": {
    "URL": "http://127.0.0.1:8081/realms/dev/protocol/openid-connect",
    "CLIENT_ID": "dev-client-oidc",
    "CLIENT_SECRET": "<REDACTED>",
    "CALLBACK": "http://127.0.0.1:3000/sso.html",
    "REISSUE": true,
    "ID_NAME": "preferred_username"
  },
  "OAUTH_OPTIONS": {
    "URL": "https://github.com/login/oauth/access_token",
    "CLIENT_ID": "a355948a635c2a2066e2",
    "CLIENT_SECRET": "<REDACTED>",
    "CALLBACK": "http://127.0.0.1:3000/sso.html",
    "USER_URL": "https://api.github.com/user",
    "USER_ID": "id",
    "USER_GROUPS": "",
    "FIND_ID": "githubId"
  },
  "T4T": {
    "CONFIGS_FOLDER_PATH": "./apps/app-t4t/tables/",
    "CONFIGS_CSV_SIZE": 500000,
    "CONFIGS_UPLOAD_SIZE": 8000000,
    "CUSTOM_PATH": "./custom",
    "USER_ID_KEY": "id",
    "USER_ROLE_KEY": "groups",
    "ORG_ID_KEY": "orgId"
  },
  "BODYPARSER_JSON": { "limit": "2mb" }, // example inline comment
  "BODYPARSER_URLENCODED": { "extended": true, "limit": "2mb" },
  // comma seperated routes to ignore e.g. '/api/healthcheck,/api/test'
  "BODYPARSER_RAW_ROUTES_NOTE" : ""
}
