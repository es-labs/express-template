{
  "name": "@common/express",
  "version": "0.0.2",
  "author": "Aaron Gong",
  "license": "MIT",
  "description": "Shareable Node Runtime JS library using ES modules",
  "keywords": [
    "javscript",
    "module"
  ],
  "homepage": "https://github.com/es-labs/express-template#readme",
  "bugs": {
    "url": "https://github.com/es-labs/express-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/es-labs/express-template.git"
  },
  "type": "module",
  "exports": {
    "./*": "./*.js",
    "./**/*": "./**/*.js"
  },
  "main": "index.js",
  "scripts": {
    "test": "node --experimental-test-coverage --test-reporter=spec --test **/__tests__/*.test.js",
    "cover": "node --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test __tests__/**/*.spec.js"
  },
  "dependencies": {
    "@common/node": "file:../node",
    "@node-saml/node-saml": "^5.1.0",
    "@scalar/express-api-reference": "^0.9.6",
    "bcryptjs": "^3.0.3",
    "connect-history-api-fallback": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "js-yaml": "^4.1.1",
    "path-to-regexp": "^8.4.2",
    "multer": "^2.1.1",
    "serve-index": "^1.9.2"
  }
}
