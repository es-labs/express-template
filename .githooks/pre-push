#!/bin/sh
# .githooks/pre-push
# Pre-push hook: runs unit tests and schema validation tests before allowing a push.
#
# Install: run .githooks/setup.sh (or: git config core.hooksPath .githooks)
# Skip:    git push --no-verify

# ── Colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Colour

print_info()    { printf "${BLUE}[pre-push]${NC} %s\n" "$1"; }
print_success() { printf "${GREEN}[pre-push]${NC} %s\n" "$1"; }
print_warning() { printf "${YELLOW}[pre-push]${NC} %s\n" "$1"; }
print_error()   { printf "${RED}[pre-push]${NC} %s\n" "$1"; }

# ── Package manager detection ─────────────────────────────────────────────────
if [ -f "pnpm-lock.yaml" ]; then
  PKG_MGR="pnpm"
elif [ -f "yarn.lock" ]; then
  PKG_MGR="yarn"
else
  PKG_MGR="npm"
fi

print_info "Using package manager: $PKG_MGR"

# ── 1. Unit tests ─────────────────────────────────────────────────────────────
print_info "Running unit tests…"

if node -e "const p=require('./package.json'); process.exit(p.scripts&&p.scripts['test:workspace']?0:1)" 2>/dev/null; then
  $PKG_MGR run test:workspace
  TEST_EXIT=$?
elif node -e "const p=require('./package.json'); process.exit(p.scripts&&p.scripts['test']?0:1)" 2>/dev/null; then
  $PKG_MGR run test
  TEST_EXIT=$?
else
  print_warning "No 'test' script found in root package.json – skipping unit tests."
  TEST_EXIT=0
fi

if [ $TEST_EXIT -ne 0 ]; then
  print_error "Unit tests failed. Fix failing tests before pushing."
  print_info  "Tip: use 'git push --no-verify' to bypass this check if necessary."
  exit 1
fi

print_success "Unit tests passed."

# ── 2. Schema validation tests ────────────────────────────────────────────────
print_info "Running schema validation tests…"

if node -e "const p=require('./package.json'); process.exit(p.scripts&&p.scripts['test:schemas']?0:1)" 2>/dev/null; then
  $PKG_MGR run test:schemas
  SCHEMA_EXIT=$?
  if [ $SCHEMA_EXIT -ne 0 ]; then
    print_error "Schema validation tests failed. Fix schema errors before pushing."
    exit 1
  fi
  print_success "Schema validation tests passed."
else
  print_warning "No 'test:schemas' script found – skipping schema tests."
fi

# ── Done ──────────────────────────────────────────────────────────────────────
print_success "All pre-push checks passed. Proceeding with push."
exit 0
